# Federated Hosting — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/fedhosting

# Object storage configuration (required)
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public

# Application environment (optional — defaults to "development")
# Set to "production" for JSON logs and no stack traces in error responses
NODE_ENV=development

# API server port (optional — defaults to 8080)
PORT=8080
