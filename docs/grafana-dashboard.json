{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "FedHost node health, traffic, federation, and system metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "green", "value": 1 }
        ] } }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background" },
      "title": "Active Sites",
      "type": "stat",
      "targets": [{ "expr": "fedhost_sites_total{status=\"active\"}", "legendFormat": "Active sites" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "red", "value": null },
        { "color": "yellow", "value": 1 },
        { "color": "green", "value": 2 }
      ] } } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Federation Peers",
      "type": "stat",
      "targets": [{ "expr": "fedhost_federation_peers_total{status=\"active\"}", "legendFormat": "Active peers" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "title": "Request Rate (RPS)",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(fedhost_http_requests_total[5m]))", "legendFormat": "RPS" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 0.5 },
        { "color": "red", "value": 2 }
      ] } } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "P99 Latency",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(fedhost_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 50 },
        { "color": "red", "value": 100 }
      ] } } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Sync Queue Depth",
      "type": "stat",
      "targets": [{ "expr": "fedhost_sync_queue_depth", "legendFormat": "Pending" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "HTTP Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "HTTP Requests/s by Status",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(fedhost_http_requests_total{status_code=~\"2..\"}[5m]))", "legendFormat": "2xx" },
        { "expr": "sum(rate(fedhost_http_requests_total{status_code=~\"4..\"}[5m]))", "legendFormat": "4xx" },
        { "expr": "sum(rate(fedhost_http_requests_total{status_code=~\"5..\"}[5m]))", "legendFormat": "5xx" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "title": "HTTP Latency Percentiles",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(fedhost_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(fedhost_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(fedhost_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "Node.js Runtime",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 21,
      "title": "Memory Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "fedhost_nodejs_heap_size_used_bytes", "legendFormat": "Heap used" },
        { "expr": "fedhost_nodejs_heap_size_total_bytes", "legendFormat": "Heap total" },
        { "expr": "fedhost_nodejs_external_memory_bytes", "legendFormat": "External" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 22,
      "title": "Event Loop Lag",
      "type": "timeseries",
      "targets": [
        { "expr": "fedhost_nodejs_eventloop_lag_seconds", "legendFormat": "Lag" },
        { "expr": "fedhost_nodejs_eventloop_lag_p99_seconds", "legendFormat": "P99 lag" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "title": "Cache & Storage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 31,
      "title": "LRU Cache Entries",
      "type": "timeseries",
      "targets": [
        { "expr": "fedhost_cache_entries{cache_type=\"domain\"}", "legendFormat": "Domain cache" },
        { "expr": "fedhost_cache_entries{cache_type=\"file\"}", "legendFormat": "File cache" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 32,
      "title": "Storage Operations/s",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(fedhost_storage_operations_total{result=\"success\"}[5m])) by (operation)", "legendFormat": "{{operation}} ok" },
        { "expr": "sum(rate(fedhost_storage_operations_total{result=\"error\"}[5m])) by (operation)", "legendFormat": "{{operation}} err" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["fedhost", "hosting", "federation"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FedHost Node",
  "uid": "fedhost-node-dashboard",
  "version": 1
}
