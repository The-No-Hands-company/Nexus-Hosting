{
  "name": "@workspace/cli",
  "version": "0.1.0",
  "description": "FedHost CLI — deploy sites to your Federated Hosting node",
  "type": "module",
  "bin": {
    "fh": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "glob": "^11.0.1",
    "mime-types": "^3.0.1",
    "conf": "^13.1.0",
    "node-fetch": "^3.3.2",
    "form-data": "^4.0.2"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
